# Auto-detect text files and normalize line endings to LF in the repo.
# Windows users keep CRLF locally; the repo and Pages build runner see LF.
* text=auto eol=lf

# Explicit text types (belt + suspenders)
*.html         text eol=lf
*.htm          text eol=lf
*.css          text eol=lf
*.js           text eol=lf
*.mjs          text eol=lf
*.json         text eol=lf
*.md           text eol=lf
*.svg          text eol=lf
*.xml          text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.txt          text eol=lf
*.toml         text eol=lf
*.sh           text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
README*        text eol=lf
LICENSE*       text eol=lf

# PowerShell scripts must keep CRLF on Windows.
*.ps1          text eol=crlf
*.cmd          text eol=crlf
*.bat          text eol=crlf

# Binary — skip diff and line-ending handling.
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.webp         binary
*.avif         binary
*.pdf          binary
*.mp4          binary
*.mov          binary
*.MOV          binary
*.zip          binary
*.woff         binary
*.woff2        binary
*.ttf          binary
*.otf          binary
*.eot          binary
