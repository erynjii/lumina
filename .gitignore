# ─────────────────────────────────────────────────────────────────
# Lumina by Mirra — repo .gitignore
#
# Strategy: ignore SPECIFIC source folders, not file extensions.
# Everything inside public/ is shipped; everything outside is local-
# only unless committed explicitly. This prevents the "negation
# didn't fire" footgun we hit earlier with blanket *.jpg rules.
# ─────────────────────────────────────────────────────────────────

# Local-only source folders (raw assets, scratch from PDF extraction).
# Files inside these never get committed. To deploy an asset, copy or
# move it to public/img/ instead.
/images/
/_tmp_extract/
/raw/
/source/

# Loose source media files at the repo root.
# Anything inside public/ is fine — these patterns are anchored with
# a leading slash, so they only match the root.
/*.mp4
/*.MOV
/*.mov
/*.psd
/*.ai
/*.sketch
/*.fig

# Loose images at the repo root (not inside public/).
/*.png
/*.jpg
/*.jpeg
/*.PNG
/*.JPG
/*.JPEG

# Secrets — never commit anywhere in the tree.
*token*.txt
*token*.env
*.token
.env
.env.*
!.env.example
*.pem
*.key

# OS / editor junk.
.DS_Store
Thumbs.db
desktop.ini
*~
.~lock.*
*.swp
*.swo
.vscode/
.idea/

# Node / build artifacts.
node_modules/
dist/
build/
.cache/
.wrangler/
